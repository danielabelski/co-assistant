# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Your Telegram User ID (for single-user auth)
TELEGRAM_USER_ID=

# GitHub Token (for Copilot SDK)
GITHUB_TOKEN=

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Default AI model
DEFAULT_MODEL=gpt-4.1

# Voice Input (optional — requires ffmpeg and whisper.cpp)
# Set VOICE_ENABLED=true and configure paths after running: co-assistant setup
VOICE_ENABLED=false
WHISPER_BINARY_PATH=
WHISPER_MODEL_PATH=
VOICE_MAX_DURATION_SECONDS=15
